<!-- Power Cycle #152: Floating "Porównaj skład" comparison button -->
<style>
.cmpFloatBtn{position:fixed;bottom:75px;left:16px;z-index:997;width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,#2e7d32,#388e3c);color:#fff;border:none;font-size:22px;box-shadow:0 4px 16px rgba(46,125,50,.35);cursor:pointer;display:flex;align-items:center;justify-content:center;text-decoration:none;animation:cmpPulse 2.5s ease-in-out 6s 3}
.cmpFloatBtn:active{transform:scale(.92)}
@keyframes cmpPulse{0%,100%{box-shadow:0 4px 16px rgba(46,125,50,.35)}50%{box-shadow:0 4px 28px rgba(46,125,50,.6)}}
@media(min-width:769px){.cmpFloatBtn{display:none!important}}
</style>
<a href="produkt.html#porownaj-sklad" class="cmpFloatBtn" aria-label="Porównaj skład">🔬</a>
